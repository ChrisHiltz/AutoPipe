# ─── Build-Pipe Environment Variables ────────────────────
#
# Copy this file to .env and fill in the values.
# .env is gitignored — never commit secrets.

# Required: Anthropic API key for Claude Code agent invocations
# Used by: nightly-cycle.sh (dispatch + research agents)
ANTHROPIC_API_KEY=

# Optional: GitHub Personal Access Token with Projects (read/write) permission
# Used by: workflow board updates (auto-move items through pipeline stages)
# Without this, board updates are silently skipped — pipeline still works.
# Setup: gh secret set PROJECT_TOKEN
# PROJECT_TOKEN=

# Auto-provided in GitHub Actions — only set manually for local script testing:
# GH_TOKEN=

# ─── Application Environment Variables ────────────────────
#
# Add your app's env vars below. Every env var your code reads MUST be listed here.
# Use non-secret defaults so `cp .env.example .env` works immediately.
#
# Format:
#   VARIABLE_NAME=default_value    # What this does
#   SECRET_VARIABLE=               # (no default — developer must provide)
#
# Examples:
#   DATABASE_URL=postgresql://localhost:5432/myapp_dev
#   REDIS_URL=redis://localhost:6379
#   API_BASE_URL=http://localhost:3000
