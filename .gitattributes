# Auto-detect text files and normalize line endings
* text=auto

# Force LF for shell scripts (prevents Windows CRLF breaking shebangs)
*.sh text eol=lf

# Force LF for CI/config files
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
Makefile text eol=lf

# Force LF for documentation (consistent diffs)
*.md text eol=lf
